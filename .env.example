# Observatorio Congreso — Configuración
# Copiar a .env y ajustar según sea necesario

# Path a la BD SQLite (default: db/congreso.db)
OBSERVATORIO_DB_PATH=db/congreso.db

# Directorio de caché (default: cache/)
OBSERVATORIO_CACHE_DIR=cache/

# Directorio de logs (default: logs/)
OBSERVATORIO_LOG_DIR=logs/

# Delay entre requests en segundos (default: 2.0)
OBSERVATORIO_DELAY=2.0

# Timeout de requests en segundos (default: 30.0)
OBSERVATORIO_TIMEOUT=30.0

# Máximo de retries (default: 3)
OBSERVATORIO_MAX_RETRIES=3

# Backoff base para reintentos (default: 2.0)
OBSERVATORIO_BACKOFF=2.0

# Tamaño de batch para inserts (default: 100)
OBSERVATORIO_BATCH_SIZE=100
